# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sai_associates"

# Auth
SESSION_SECRET="change-this-long-secret"
SESSION_COOKIE_NAME="sai_session"
SESSION_TTL_HOURS="12"

# OTP
OTP_EXPIRY_MINUTES="10"
OTP_DEV_FALLBACK="true"

# Supabase uploads (optional)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="uploads"

# Preview mode fallback (in-memory store)
PUBLIC_PREVIEW_MODE="true"
