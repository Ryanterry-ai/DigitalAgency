generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  employee
}

enum ActiveStatus {
  active
  inactive
}

enum AttendanceStatus {
  present
  absent
  half_day
}

enum IssueStatus {
  pending
  resolved
}

enum IssueType {
  down
  dispenser_problem
  cash_issue
  network_issue
  power_issue
  other
}

enum ExpenseType {
  salary
  advance
  petrol
  maintenance
  other
}

enum OrderStatus {
  new
  confirmed
  delivered
  canceled
}

enum NotificationType {
  issue
  follow_up
  expense
  attendance
  system
}

model User {
  id           String         @id @default(cuid())
  mobile       String         @unique
  role         UserRole
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  employee     Employee?
  notifications Notification[]
  otpTokens    OtpToken[]
}

model Employee {
  id             String          @id @default(cuid())
  userId         String?         @unique
  employeeCode   String          @unique
  fullName       String
  email          String?
  mobile         String          @unique
  location       String?
  joiningDate    DateTime?
  status         ActiveStatus    @default(active)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  atmSites       AtmSite[]
  attendanceLogs AttendanceLog[]
  salaryRecords  SalaryRecord[]
  expenseRecords ExpenseRecord[]
  siteVisits     SiteVisit[]
  retailVisits   RetailVisit[]
  orders         Order[]
}

model AtmSite {
  id                 String        @id @default(cuid())
  siteName           String
  siteCode           String        @unique
  address            String
  city               String
  assignedEmployeeId String?
  status             ActiveStatus  @default(active)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  assignedEmployee   Employee?     @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  expenseRecords     ExpenseRecord[]
  siteVisits         SiteVisit[]
}

model AttendanceLog {
  id               String           @id @default(cuid())
  employeeId       String
  attendanceDate   DateTime
  punchIn          DateTime?
  punchOut         DateTime?
  punchInLocation  String?
  punchOutLocation String?
  workingMinutes   Int?
  status           AttendanceStatus @default(present)
  createdAt        DateTime         @default(now())
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalaryRecord {
  id           String    @id @default(cuid())
  employeeId   String
  monthLabel   String
  salaryAmount Decimal   @db.Decimal(12, 2)
  advanceAmount Decimal  @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime  @default(now())
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ExpenseRecord {
  id          String      @id @default(cuid())
  employeeId  String?
  atmSiteId   String?
  expenseType ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  expenseDate DateTime
  notes       String?
  proofUrl    String?
  createdAt   DateTime    @default(now())
  employee    Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  atmSite     AtmSite?    @relation(fields: [atmSiteId], references: [id], onDelete: SetNull)
}

model SiteVisit {
  id           String     @id @default(cuid())
  atmSiteId    String
  employeeId   String
  issueType    IssueType
  expenseAmount Decimal   @db.Decimal(12, 2)
  notes        String?
  photoUrl     String
  status       IssueStatus
  visitedAt    DateTime   @default(now())
  createdAt    DateTime   @default(now())
  atmSite      AtmSite    @relation(fields: [atmSiteId], references: [id], onDelete: Cascade)
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Retailer {
  id           String      @id @default(cuid())
  shopName     String
  ownerName    String
  mobile       String
  address      String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  retailVisits RetailVisit[]
  orders       Order[]
}

model RetailVisit {
  id          String    @id @default(cuid())
  retailerId  String
  employeeId  String
  visitDate   DateTime
  visitTime   String
  notes       String?
  photoUrls   String[]
  createdAt   DateTime  @default(now())
  retailer    Retailer  @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Order {
  id           String      @id @default(cuid())
  retailerId   String
  employeeId   String?
  productName  String
  quantity     Int
  followUpDate DateTime?
  orderStatus  OrderStatus @default(new)
  notes        String?
  createdAt    DateTime    @default(now())
  retailer     Retailer    @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  title     String
  message   String
  type      NotificationType @default(system)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
